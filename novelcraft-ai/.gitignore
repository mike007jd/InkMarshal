# Vendored engine binaries — fetched at build time via `pnpm fetch-engines`.
# Keep the resource directory itself present for Tauri's fresh-clone build script.
src-tauri/resources/engines/*
!src-tauri/resources/engines/.gitkeep

# Swift MLX server build artifacts (SwiftPM + xcodebuild derived data).
# The package SOURCE (Package.swift, Sources/) IS committed.
src-tauri/engines/mlx-server/.build/

