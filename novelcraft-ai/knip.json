{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/{page,route,layout,error,not-found,loading,template,default,opengraph-image,robots,sitemap,icon}.{ts,tsx,js,jsx}",
    "src-tauri/src/**/*.rs",
    "scripts/**/*.{mjs,js,ts}",
    "**/*.{test,spec}.{ts,tsx}"
