{
  "name": "novelcraft-ai",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=10.15.1 <11"
  },
  "scripts": {
    "dev": "next dev",
    "dev:desktop-web": "next dev --hostname 127.0.0.1 --port 1420",
    "prepare:desktop-dev": "pnpm fetch-engines",
    "desktop:dev": "pnpm prepare:desktop-dev && tauri dev",
    "desktop:build": "node scripts/build-mac-desktop.mjs",
    "clean:desktop-build": "node scripts/clean-build-artifacts.mjs",
    "build:desktop-web": "node scripts/build-tauri-web.mjs",
    "ralph": "bash scripts/ralph/ralph.sh",
    "qa:seed-full-novel": "node scripts/seed-full-novel-qa-data.mjs",
    "qa:full-novel-coverage": "vitest run scripts/full-novel-qa.test.ts",
    "qa:assert-full-novel": "node scripts/assert-full-novel-qa-data.mjs",
    "fetch-engines": "node scripts/fetch-engines.mjs",
    "local-state:reset": "node scripts/reset-inkmarshal-local-state.mjs",
    "local-state:relocate": "node scripts/relocate-dot-state.mjs",
    "release:mac": "node scripts/build-mac-release.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check:ui-framework": "vitest run components/design-system-contract.static.test.ts",
    "clean": "node scripts/clean-build-artifacts.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "smoke:desktop": "node e2e/desktop-smoke/run-standalone-smoke.mjs",
    "ai:freshness": "vitest run lib/providers.test.ts lib/model-supply/catalog.test.ts",
    "audit:js": "node scripts/run-osv-scanner.mjs",
    "audit:rust": "node scripts/run-cargo-audit.mjs",
    "verify:security": "pnpm audit:js && pnpm audit:rust",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:desktop": "cd src-tauri && cargo fmt --check && cargo clippy --locked --all-targets -- -D warnings && cargo test --locked",
    "verify:all": "pnpm verify && pnpm verify:security && pnpm verify:desktop",
    "verify:release-desktop": "node scripts/validate-desktop-release.mjs",
    "verify:mac-library-validation": "node scripts/verify-mac-library-validation.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@ai-sdk/react": "3.0.210",
    "@assistant-ui/react": "^0.14.23",
    "@assistant-ui/react-ai-sdk": "1.3.37",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@lexical/react": "^0.44.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.1",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "2.10.1",
    "ai": "^6.0.208",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "docx": "^9.6.0",
    "fflate": "^0.8.2",
    "lexical": "^0.44.0",
    "lucide-react": "^0.553.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-pageflip": "^2.0.3",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tauri-apps/cli": "2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.1.1",
    "knip": "^6.22.0",
    "tailwindcss": "4.1.11",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "^4.1.5"
  }
}
