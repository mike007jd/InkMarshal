{
  "loopId": "example-long-novel-pass",
  "novelId": "replace-with-local-novel-id",
  "description": "Advance a long-form manuscript through InkMarshal's Ralph writing loop.",
  "stopWhen": {
    "draftComplete": true,
    "maxChaptersThisRun": 12
  },
  "qualityGate": {
    "allowMajorIssues": false,
    "minScore": 88,
    "maxAutomaticRevisionsPerChapter": 1
  },
  "notes": "The app route owns draft, validate, repair, summarize, and persistence. This outer loop only advances persisted writing units and records continuity memory."
}
